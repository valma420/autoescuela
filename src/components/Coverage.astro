---
import { coverage, site } from '../data/site';

// Mapa embebido de OpenStreetMap centrado en la zona (sin API key ni JS).
const { lat, lng } = site.location.geo;
const bbox = `${lng - 0.03}%2C${lat - 0.02}%2C${lng + 0.03}%2C${lat + 0.02}`;
const mapSrc = `https://www.openstreetmap.org/export/embed.html?bbox=${bbox}&layer=mapnik&marker=${lat}%2C${lng}`;
---

<section id="cobertura" class="bg-slate-50 py-16 sm:py-20">
  <div class="mx-auto max-w-6xl px-4">
    <div class="grid items-center gap-10 lg:grid-cols-2">
      <div>
        <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
          {coverage.title}
        </h2>
        <p class="mt-4 text-lg text-slate-600">{coverage.description}</p>

        <ul class="mt-6 flex flex-wrap gap-2">
          {
            coverage.areas.map((area) => (
              <li class="inline-flex items-center gap-1.5 rounded-lg border border-slate-200 bg-white px-3 py-1.5 text-sm font-medium text-slate-700">
                <span class="text-brand-600" aria-hidden="true">
                  📍
                </span>
                {area}
              </li>
            ))
          }
        </ul>
      </div>

      <div
        class="overflow-hidden rounded-2xl border border-slate-200 shadow-sm"
      >
        <iframe
          title={`Mapa de cobertura: ${site.location.coverageNote}`}
          src={mapSrc}
          width="100%"
          height="360"
          loading="lazy"
          class="block h-[360px] w-full border-0"
        ></iframe>
      </div>
    </div>
  </div>
</section>
