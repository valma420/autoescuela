---
import { coverage, site } from '../data/site';
---

<section id="cobertura" class="bg-white py-16 sm:py-24">
  <div class="mx-auto max-w-6xl px-4">
    <div class="grid items-center gap-10 lg:grid-cols-[0.9fr_1.1fr]">
      <div>
        <p class="text-sm font-bold uppercase tracking-[0.22em] text-brand-600">
          Cobertura
        </p>
        <h2 class="mt-3 text-3xl font-black tracking-tight text-brand-950 sm:text-5xl">
          {coverage.title}
        </h2>
        <p class="mt-4 text-lg leading-8 text-slate-600">{coverage.description}</p>

        <ul class="mt-8 flex flex-wrap gap-2">
          {
            coverage.areas.map((area) => (
              <li class="inline-flex items-center rounded-lg border border-accent-300 bg-accent-50 px-3 py-1.5 text-sm font-bold text-brand-950">
                {area}
              </li>
            ))
          }
        </ul>
      </div>

      <div class="relative overflow-hidden rounded-lg bg-brand-950 shadow-2xl shadow-slate-200/70">
        <img
          src={site.assets.ctaImage}
          alt=""
          width="1200"
          height="800"
          loading="lazy"
          class="h-[380px] w-full object-cover opacity-70"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-brand-950 via-brand-950/25 to-transparent"></div>
        <div class="absolute bottom-5 left-5 right-5 rounded-lg bg-white/95 p-5 shadow-lg">
          <p class="text-xs font-bold uppercase tracking-[0.18em] text-brand-600">
            Zona base
          </p>
          <p class="mt-1 text-xl font-black text-brand-950">
            {site.location.coverageNote}
          </p>
          <p class="mt-2 text-sm leading-6 text-slate-600">
            Clases prácticas coordinadas desde Villa Urquiza y barrios cercanos.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
