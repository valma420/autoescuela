---
import { site } from '../data/site';
---

<a
  href={site.contact.whatsappUrl}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Escribinos por WhatsApp"
  class="fixed bottom-5 right-5 z-40 inline-flex h-14 w-14 items-center justify-center rounded-full bg-accent-500 text-2xl text-white shadow-lg transition hover:bg-accent-600 hover:scale-105 focus:outline-none focus-visible:ring-2 focus-visible:ring-accent-600 focus-visible:ring-offset-2"
>
  <span aria-hidden="true">💬</span>
</a>
