---
import { faqs } from '../data/site';
---

<section id="faq" class="bg-white py-16 sm:py-24">
  <div class="mx-auto max-w-3xl px-4">
    <div class="text-center">
      <p class="text-sm font-bold uppercase tracking-[0.22em] text-brand-600">
        Dudas
      </p>
      <h2 class="mt-3 text-3xl font-black tracking-tight text-brand-950 sm:text-5xl">
        Preguntas frecuentes
      </h2>
      <p class="mt-4 text-lg leading-8 text-slate-600">
        Resolvé tus dudas antes de tu primera clase de manejo.
      </p>
    </div>

    <div class="mt-10 space-y-4">
      {
        faqs.map((faq) => (
          <details class="group rounded-lg border border-slate-200 bg-slate-50 p-5 [&_summary::-webkit-details-marker]:hidden">
            <summary class="flex cursor-pointer items-center justify-between gap-4 font-black text-brand-950">
              {faq.question}
              <span
                class="grid h-8 w-8 shrink-0 place-items-center rounded-lg bg-accent-400 text-brand-950 transition-transform group-open:rotate-45"
                aria-hidden="true"
              >
                +
              </span>
            </summary>
            <p class="mt-3 leading-7 text-slate-600">{faq.answer}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>
