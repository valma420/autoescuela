---
import { faqs } from '../data/site';
---

<section id="faq" class="bg-slate-50 py-16 sm:py-20">
  <div class="mx-auto max-w-3xl px-4">
    <div class="text-center">
      <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
        Preguntas frecuentes
      </h2>
      <p class="mt-4 text-lg text-slate-600">
        Resolvé tus dudas antes de tu primera clase de manejo.
      </p>
    </div>

    <div class="mt-10 space-y-4">
      {
        faqs.map((faq) => (
          <details class="group rounded-xl border border-slate-200 bg-white p-5 [&_summary::-webkit-details-marker]:hidden">
            <summary class="flex cursor-pointer items-center justify-between gap-4 font-semibold text-slate-900">
              {faq.question}
              <span
                class="text-brand-600 transition-transform group-open:rotate-45"
                aria-hidden="true"
              >
                +
              </span>
            </summary>
            <p class="mt-3 text-slate-600">{faq.answer}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>
