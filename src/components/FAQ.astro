---
import { faqs } from '../data/site';
---

<section id="faq" class="ak-section bg-brand-100 text-brand-950">
  <div class="ak-container max-w-4xl">
    <div>
      <h2 class="font-display text-4xl font-black uppercase leading-[0.96] sm:text-5xl">
        Preguntas frecuentes
      </h2>
      <p class="mt-5 max-w-xl text-base leading-7 text-brand-800/75">
        Resolvé tus dudas antes de tu primera clase de manejo.
      </p>
    </div>

    <div class="mt-8 space-y-3">
      {
        faqs.map((faq) => (
          <details class="group rounded-md bg-white p-5 shadow-[0_10px_24px_-14px_rgba(25,26,51,0.4)] [&_summary::-webkit-details-marker]:hidden">
            <summary class="ak-focus flex min-h-11 cursor-pointer items-center justify-between gap-4 font-black">
              {faq.question}
              <span
                class="grid h-9 w-9 shrink-0 place-items-center rounded-full bg-brand-100 text-brand-950 transition-transform duration-200 group-open:rotate-45"
                aria-hidden="true"
              >
                +
              </span>
            </summary>
            <p class="mt-3 leading-7 text-brand-800/75">{faq.answer}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>
