---
import { teacher } from '../data/site';
---

<section id="profesor" class="bg-white py-16 sm:py-20">
  <div class="mx-auto max-w-6xl px-4">
    <div class="grid items-center gap-10 lg:grid-cols-[2fr_3fr]">
      <div class="order-2 lg:order-1">
        <div
          class="mx-auto aspect-square w-full max-w-sm rounded-2xl bg-gradient-to-br from-slate-100 to-brand-100 p-1 shadow-md"
        >
          <img
            src={teacher.photo}
            alt={`Foto de ${teacher.role}`}
            width="400"
            height="400"
            loading="lazy"
            class="h-full w-full rounded-xl object-cover"
          />
        </div>
      </div>

      <div class="order-1 lg:order-2">
        <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
          Quién te va a enseñar
        </h2>
        <p class="mt-2 text-lg font-medium text-brand-700">{teacher.role}</p>

        <div class="mt-5 space-y-4 text-slate-600">
          {teacher.bio.map((paragraph) => <p>{paragraph}</p>)}
        </div>

        <ul class="mt-6 flex flex-wrap gap-3">
          {
            teacher.credentials.map((c) => (
              <li class="rounded-lg bg-brand-50 px-3 py-1.5 text-sm font-medium text-brand-700">
                {c}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
