---
import { teacher } from '../data/site';
---

<section id="profesor" class="ak-section relative bg-brand-950 text-white">
  <div class="ak-container">
    <p class="absolute left-[22px] top-6 text-[13px] font-semibold tracking-[2px] text-accent-400">03</p>
    <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <div class="relative overflow-hidden rounded-[20px] bg-brand-800">
        <img
          src={teacher.photo}
          alt="Persona dentro de un auto durante una práctica de manejo"
          width="1200"
          height="1200"
          loading="lazy"
          class="aspect-[342/438] w-full object-cover object-[76%_55%] brightness-75 contrast-90 saturate-75 md:aspect-[0.96]"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-brand-950/60 via-brand-950/15 to-brand-800/30"></div>
        <div class="absolute bottom-4 left-4 rounded-[10px] bg-white px-4 py-3 text-brand-950 shadow-[0_14px_28px_-16px_rgba(0,0,0,0.7)]">
          <p class="text-sm font-black">Matriculado</p>
          <p class="mt-1 text-xs font-semibold text-brand-800/70">{teacher.role}</p>
        </div>
      </div>

      <div>
        <h2 class="font-display text-[30px] font-black leading-[1.04] tracking-[-0.015em] sm:text-6xl">
          {teacher.name}
        </h2>
        <p class="mt-3 text-base text-brand-200 md:text-lg">
          {teacher.role}
        </p>

        <div class="mt-5 max-w-2xl space-y-[14px] text-[15px] leading-[1.5] text-brand-100 md:text-lg md:leading-8">
          {teacher.bio.map((paragraph) => <p>{paragraph}</p>)}
        </div>

        <ul class="mt-6 flex flex-wrap gap-2">
          {
            teacher.credentials.map((c) => (
              <li class="ak-pill bg-brand-800 text-brand-100">
                <span class="ak-dot"></span>
                {c}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
