---
import { teacher } from '../data/site';
---

<section id="profesor" class="ak-section bg-brand-950 text-white">
  <div class="ak-container">
    <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <div class="relative overflow-hidden rounded-md bg-brand-800">
        <img
          src={teacher.photo}
          alt="Persona dentro de un auto durante una práctica de manejo"
          width="1200"
          height="1200"
          loading="lazy"
          class="aspect-[0.96] w-full object-cover object-[76%_55%] brightness-125 contrast-90 saturate-110"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-brand-950/48 via-transparent to-transparent"></div>
        <div class="absolute bottom-4 left-4 rounded-md bg-white px-4 py-3 text-brand-950 shadow-[0_14px_28px_-16px_rgba(0,0,0,0.7)]">
          <p class="text-sm font-black">Matriculado</p>
          <p class="mt-1 text-xs font-semibold text-brand-800/70">{teacher.role}</p>
        </div>
      </div>

      <div>
        <h2 class="font-display max-w-[9ch] text-4xl font-black uppercase leading-[0.92] sm:text-6xl">
          {teacher.name}
        </h2>
        <p class="mt-5 text-base font-black text-accent-300 md:text-lg">
          {teacher.role}
        </p>

        <div class="mt-7 max-w-2xl space-y-4 text-base leading-7 text-brand-100/86 md:text-lg md:leading-8">
          {teacher.bio.map((paragraph) => <p>{paragraph}</p>)}
        </div>

        <ul class="mt-8 flex flex-wrap gap-2">
          {
            teacher.credentials.map((c) => (
              <li class="ak-pill bg-brand-800 text-brand-100">
                <span class="ak-dot"></span>
                {c}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
