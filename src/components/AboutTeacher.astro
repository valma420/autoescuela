---
import { teacher } from '../data/site';
---

<section id="profesor" class="bg-white py-16 sm:py-24">
  <div class="mx-auto max-w-6xl px-4">
    <div class="grid items-center gap-12 lg:grid-cols-[1.05fr_0.95fr]">
      <div>
        <p class="text-sm font-bold uppercase tracking-[0.22em] text-brand-600">
          Instructor
        </p>
        <h2 class="mt-3 text-3xl font-black tracking-tight text-brand-950 sm:text-5xl">
          {teacher.name}
        </h2>
        <p class="mt-3 text-lg font-bold text-brand-700">{teacher.role}</p>

        <div class="mt-6 max-w-2xl space-y-4 text-base leading-8 text-slate-600">
          {teacher.bio.map((paragraph) => <p>{paragraph}</p>)}
        </div>

        <ul class="mt-8 grid gap-3 sm:grid-cols-3">
          {
            teacher.credentials.map((c) => (
              <li class="rounded-lg border border-slate-200 bg-slate-50 p-4 text-sm font-bold text-brand-950">
                <span class="mb-3 block h-1.5 w-10 rounded-full bg-accent-400"></span>
                {c}
              </li>
            ))
          }
        </ul>
      </div>

      <div class="relative">
        <div class="absolute -bottom-5 -left-5 h-24 w-32 rounded-lg bg-accent-400"></div>
        <div class="relative overflow-hidden rounded-lg bg-brand-950 shadow-2xl">
          <img
            src={teacher.photo}
            alt="Persona en una clase de manejo"
            width="1200"
            height="1200"
            loading="lazy"
            class="aspect-[4/5] w-full object-cover opacity-90"
          />
        </div>
      </div>
    </div>
  </div>
</section>
