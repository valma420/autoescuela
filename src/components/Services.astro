---
import { hero, services, site } from '../data/site';
---

<section id="servicios" class="ak-section bg-brand-100 text-brand-950">
  <div class="ak-container">
    <div class="max-w-2xl">
      <h2 class="font-display text-[30px] font-black leading-none tracking-[-0.01em] sm:text-5xl">
        Clases a medida
      </h2>
      <p class="mt-[14px] max-w-xl text-base leading-6 text-brand-800/80 md:text-lg">
        Cada clase apunta a una meta concreta: arrancar de cero, ganar calle o
        practicar para el examen de CABA.
      </p>
    </div>

    <ul class="mt-6 flex flex-wrap gap-2">
      {
        hero.highlights.map((item) => (
          <li class="inline-flex min-h-9 items-center gap-2 rounded-full bg-white px-[13px] text-[13px] font-medium text-brand-950">
            <span class="ak-dot"></span>
            {item}
          </li>
        ))
      }
    </ul>

    <ul class="mt-5 grid gap-3 md:grid-cols-2">
      {
        services.map((service, index) => (
          <li
            class:list={[
              'rounded-[18px] px-[22px] pb-6 pt-[22px] shadow-[0_8px_20px_-6px_rgba(26,77,115,0.15)] transition duration-200 hover:-translate-y-0.5',
              index === 0
                ? 'bg-brand-950 text-white'
                : 'bg-white text-brand-950',
            ]}
          >
            <div class="flex items-start justify-between gap-4">
              <h3 class="text-[22px] font-bold leading-[1.1] tracking-[-0.01em]">{service.title}</h3>
              <a
                href={site.contact.whatsappUrl}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`Consultar por ${service.title}`}
                class:list={[
                  'ak-focus grid h-9 w-9 shrink-0 place-items-center rounded-full text-lg font-black transition',
                  index === 0
                    ? 'bg-accent-400 text-brand-950 hover:bg-white'
                    : 'bg-brand-100 text-brand-950 hover:bg-accent-400',
                ]}
              >
                →
              </a>
            </div>
            <p
              class:list={[
                'mt-3 text-sm font-medium leading-[1.45]',
                index === 0 ? 'text-brand-100' : 'text-brand-800/75',
              ]}
            >
              {service.description}
            </p>
          </li>
        ))
      }
    </ul>

  </div>
</section>
