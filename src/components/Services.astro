---
import { services } from '../data/site';
---

<section id="servicios" class="bg-slate-50 py-16 sm:py-20">
  <div class="mx-auto max-w-6xl px-4">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
        Clases y servicios
      </h2>
      <p class="mt-4 text-lg text-slate-600">
        Elegí el tipo de clase de manejo que mejor se adapta a vos, desde tus
        primeras prácticas hasta el examen de la licencia.
      </p>
    </div>

    <ul class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        services.map((service) => (
          <li class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-brand-300 hover:shadow-md">
            <span class="text-3xl" aria-hidden="true">
              {service.icon}
            </span>
            <h3 class="mt-4 text-lg font-semibold text-slate-900">
              {service.title}
            </h3>
            <p class="mt-2 text-sm text-slate-600">{service.description}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
