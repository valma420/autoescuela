---
import { services, site } from '../data/site';
---

<section id="servicios" class="bg-slate-100 py-16 sm:py-24">
  <div class="mx-auto max-w-6xl px-4">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-bold uppercase tracking-[0.22em] text-brand-600">
        Clases
      </p>
      <h2 class="mt-3 text-3xl font-black tracking-tight text-brand-950 sm:text-5xl">
        Clases y servicios
      </h2>
      <p class="mt-4 text-lg leading-8 text-slate-600">
        Elegí el tipo de clase de manejo que mejor se adapta a vos, desde tus
        primeras prácticas hasta el examen de la licencia.
      </p>
    </div>

    <ul class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
      {
        services.map((service) => (
          <li class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-lg shadow-slate-200/70 transition hover:-translate-y-1 hover:shadow-xl">
            <img
              src={service.image}
              alt=""
              width="1200"
              height="800"
              loading="eager"
              class="h-44 w-full object-cover"
            />
            <div class="p-5">
              <span
                class="grid h-11 w-11 place-items-center rounded-lg bg-accent-400 text-xl"
                aria-hidden="true"
              >
                {service.icon}
              </span>
              <h3 class="mt-4 text-lg font-black text-brand-950">{service.title}</h3>
              <p class="mt-2 text-sm leading-6 text-slate-600">{service.description}</p>
              <a
                href={site.contact.whatsappUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-5 inline-flex w-full items-center justify-center rounded-lg bg-accent-400 px-4 py-2.5 text-sm font-black text-brand-950 transition hover:bg-accent-300"
              >
                Consultar
              </a>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>
