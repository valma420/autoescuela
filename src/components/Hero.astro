---
import { hero, site } from '../data/site';
---

<section class="bg-slate-50 px-4 py-6 sm:py-8">
  <div class="mx-auto max-w-6xl">
    <div
      class="relative isolate overflow-hidden rounded-lg bg-brand-950 px-5 py-16 shadow-2xl sm:px-10 sm:py-20 lg:px-14 lg:py-24"
    >
      <img
        src={site.assets.heroImage}
        alt="Persona manejando durante una clase de manejo"
        width="1800"
        height="1200"
        loading="eager"
        class="absolute inset-0 -z-20 h-full w-full object-cover"
      />
      <div class="absolute inset-0 -z-10 bg-gradient-to-r from-brand-950 via-brand-950/82 to-brand-950/15"></div>

      <div class="max-w-2xl">
        <p class="text-sm font-bold uppercase tracking-[0.24em] text-accent-400">
          {hero.eyebrow}
        </p>
        <h1 class="mt-5 text-4xl font-black tracking-tight text-white sm:text-5xl lg:text-6xl">
          {hero.title}
        </h1>
        <p class="mt-5 max-w-xl text-base leading-8 text-slate-200 sm:text-lg">
          {hero.subtitle}
        </p>

        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a
            href={site.contact.whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center rounded-full bg-accent-400 px-7 py-3 text-base font-black text-brand-950 shadow-lg shadow-black/20 transition hover:bg-accent-300 focus:outline-none focus-visible:ring-2 focus-visible:ring-accent-300 focus-visible:ring-offset-2 focus-visible:ring-offset-brand-950"
          >
            {hero.primaryCta}
          </a>
          <a
            href="#servicios"
            class="inline-flex items-center justify-center rounded-full border border-white/40 bg-white/10 px-7 py-3 text-base font-bold text-white backdrop-blur transition hover:bg-white hover:text-brand-950"
          >
            {hero.secondaryCta}
          </a>
        </div>

        <dl class="mt-10 grid max-w-xl grid-cols-2 gap-4 sm:grid-cols-3">
          {
            hero.stats.map((stat) => (
              <div>
                <dt class="text-3xl font-black text-accent-400">{stat.value}</dt>
                <dd class="mt-1 text-xs font-semibold uppercase tracking-wide text-slate-300">
                  {stat.label}
                </dd>
              </div>
            ))
          }
        </dl>
      </div>
    </div>

    <ul class="mt-5 grid gap-4 px-2 sm:grid-cols-3 sm:px-8">
      {
        hero.highlights.map((item) => (
          <li class="rounded-lg border border-slate-200 bg-white p-5 text-center shadow-xl shadow-slate-200/70">
            <span class="mx-auto grid h-11 w-11 place-items-center rounded-lg bg-accent-400 text-lg font-black text-brand-950">
              ✓
            </span>
            <p class="mt-3 text-sm font-black text-brand-950">{item}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
