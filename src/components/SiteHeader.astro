---
import { site } from '../data/site';

const navItems = [
  { href: '#servicios', label: 'Servicios' },
  { href: '#beneficios', label: 'Beneficios' },
  { href: '#cobertura', label: 'Zonas' },
  { href: '#faq', label: 'FAQ' },
];
---

<header class="sticky top-0 z-30 border-b border-slate-200/80 bg-white/95 backdrop-blur">
  <div class="border-b border-slate-200 bg-accent-400 text-xs font-semibold text-brand-950">
    <div
      class="mx-auto flex max-w-6xl flex-col gap-1 px-4 py-2 text-center sm:flex-row sm:items-center sm:justify-between sm:text-left"
    >
      <span>{site.contact.schedule}</span>
      <a href={`tel:${site.contact.phoneInternational}`} class="hover:underline">
        {site.contact.phoneDisplay}
      </a>
    </div>
  </div>

  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-4">
    <a href="/" class="flex items-center gap-3" aria-label={`${site.name} inicio`}>
      <span
        class="grid h-10 w-10 place-items-center rounded-lg bg-brand-950 text-sm font-black text-accent-400 shadow-sm"
        aria-hidden="true"
      >
        AK
      </span>
      <span class="leading-tight">
        <span class="block text-base font-black tracking-tight text-brand-950">
          {site.shortName}
        </span>
        <span class="block text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">
          autoescuela
        </span>
      </span>
    </a>

    <nav class="hidden items-center gap-7 text-sm font-semibold text-slate-700 md:flex">
      {
        navItems.map((item) => (
          <a class="transition hover:text-brand-800" href={item.href}>
            {item.label}
          </a>
        ))
      }
    </nav>

    <a
      href={site.contact.whatsappUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center justify-center rounded-full bg-brand-950 px-4 py-2 text-sm font-bold text-white shadow-sm transition hover:bg-brand-800 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-700 focus-visible:ring-offset-2"
    >
      Reservar
    </a>
  </div>
</header>
