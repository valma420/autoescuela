---
import { site } from '../data/site';

const navItems = [
  { href: '#servicios', label: 'Servicios' },
  { href: '#cobertura', label: 'Zonas' },
  { href: '#profesor', label: 'Instructor' },
  { href: '#beneficios', label: 'Beneficios' },
];
---

<header class="absolute inset-x-0 top-0 z-40 bg-brand-950 md:fixed md:bg-gradient-to-b md:from-brand-950/90 md:to-transparent">
  <div class="mx-auto flex h-[84px] max-w-6xl items-center justify-between gap-4 px-[30px] md:min-h-20 md:px-8 md:py-3">
    <a href="/" class="ak-focus relative h-[60px] w-[171px] shrink-0 md:flex md:items-center" aria-label={`${site.name} inicio`}>
      <span class="md:hidden">
        <img src="/images/akdemia-menu-logo-car.svg" alt="" width="120" height="51" class="absolute left-[14.8%] top-[7.38%] h-[85.25%] w-[70.4%]" />
        <img src="/images/akdemia-menu-logo-wordmark.svg" alt={site.name} width="91" height="13" class="absolute left-[22.86%] top-[40.65%] h-[21.95%] w-[53.15%]" />
        <img src="/images/akdemia-menu-logo-subtitle.svg" alt="" width="64" height="7" class="absolute left-[30.56%] top-[64.67%] h-[10.86%] w-[37.44%]" />
      </span>
      <img
        src={site.assets.logo}
        alt={site.name}
        width="864"
        height="391"
        class="hidden h-14 w-auto max-w-[172px] object-contain md:block"
      />
    </a>

    <nav class="hidden items-center gap-8 text-sm font-black text-white md:flex">
      {
        navItems.map((item) => (
          <a class="ak-focus transition hover:text-accent-300" href={item.href}>
            {item.label}
          </a>
        ))
      }
    </nav>

    <a
      href={site.contact.whatsappUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="ak-focus hidden min-h-12 items-center justify-center rounded-full bg-accent-400 px-5 text-sm font-black uppercase text-brand-950 shadow-[0_10px_24px_-4px_rgba(0,158,226,0.35)] transition hover:bg-brand-100 md:inline-flex"
    >
      Agendá
    </a>

    <button
      aria-controls="mobile-navigation"
      aria-expanded="false"
      aria-label="Abrir menú"
      class="ak-focus relative grid h-11 w-11 place-items-center text-brand-100 md:hidden"
      data-menu-toggle
      type="button"
    >
      <span class="sr-only">Menú</span>
      <span class="absolute h-0.5 w-5 -translate-y-1.5 rounded-full bg-current"></span>
      <span class="absolute h-0.5 w-5 rounded-full bg-current"></span>
      <span class="absolute h-0.5 w-5 translate-y-1.5 rounded-full bg-current"></span>
    </button>
  </div>
</header>

<div
  aria-hidden="true"
  aria-label="Navegación móvil"
  class="invisible fixed inset-0 z-50 flex flex-col bg-brand-950 text-brand-100 opacity-0 transition-all duration-300 md:hidden"
  data-mobile-menu
  id="mobile-navigation"
  role="dialog"
>
  <div class="flex h-[86px] items-center justify-end gap-[57px] px-[30px]">
    <a class="ak-focus relative h-[60px] w-[171px] shrink-0" href="/" aria-label={`${site.name} inicio`} data-menu-link>
      <img
        src="/images/akdemia-menu-logo-car.svg"
        alt=""
        width="120"
        height="51"
        class="absolute left-[14.8%] top-[7.38%] h-[85.25%] w-[70.4%]"
      />
      <img
        src="/images/akdemia-menu-logo-wordmark.svg"
        alt={site.name}
        width="91"
        height="13"
        class="absolute left-[22.86%] top-[40.65%] h-[21.95%] w-[53.15%]"
      />
      <img
        src="/images/akdemia-menu-logo-subtitle.svg"
        alt=""
        width="64"
        height="7"
        class="absolute left-[30.56%] top-[64.67%] h-[10.86%] w-[37.44%]"
      />
    </a>
    <button
      aria-label="Cerrar menú"
      class="ak-focus grid h-[22px] w-[22px] place-items-center text-[22px] font-medium leading-none text-brand-100"
      data-menu-close
      type="button"
    >
      <span aria-hidden="true">✕</span>
    </button>
  </div>

  <div class="flex flex-1 flex-col px-6 pt-6">
    <nav aria-label="Navegación móvil">
      <ul>
        {
          navItems.map((item) => (
            <li class="border-b border-brand-750">
              <a
                class="ak-focus flex py-[18px] font-display text-[25px] font-semibold leading-[1.1] tracking-[-0.01em] text-white uppercase transition hover:text-accent-300"
                href={item.href}
                data-menu-link
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
    <a
      href={site.contact.whatsappUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="ak-focus mx-auto mt-auto mb-[3.5rem] inline-flex min-h-[3.125rem] w-full max-w-[342px] items-center justify-center rounded-full bg-accent-400 px-5 text-xs font-semibold tracking-[0.04em] text-[#f5f5f5] uppercase transition hover:bg-brand-100 hover:text-brand-950"
      data-menu-link
    >
      Agendá tu clase
    </a>
  </div>
</div>

<script>
  const menu = document.querySelector<HTMLElement>('[data-mobile-menu]');
  const toggle = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
  const closeButton = document.querySelector<HTMLButtonElement>('[data-menu-close]');
  const menuLinks = menu?.querySelectorAll<HTMLAnchorElement>('[data-menu-link]');
  const desktopBreakpoint = window.matchMedia('(min-width: 768px)');
  let previousOverflow = '';

  const setMenuOpen = (open: boolean) => {
    if (!menu || !toggle) return;

    menu.classList.toggle('invisible', !open);
    menu.classList.toggle('pointer-events-none', !open);
    menu.classList.toggle('opacity-0', !open);
    menu.classList.toggle('opacity-100', open);
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú');
    menu.setAttribute('aria-hidden', String(!open));

    if (open) {
      previousOverflow = document.body.style.overflow;
      document.body.style.overflow = 'hidden';
      closeButton?.focus();
      return;
    }

    document.body.style.overflow = previousOverflow;
  };

  toggle?.addEventListener('click', () => {
    setMenuOpen(toggle.getAttribute('aria-expanded') !== 'true');
  });

  closeButton?.addEventListener('click', () => {
    setMenuOpen(false);
    toggle?.focus();
  });

  menuLinks?.forEach((link) => link.addEventListener('click', () => setMenuOpen(false)));

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && toggle?.getAttribute('aria-expanded') === 'true') {
      setMenuOpen(false);
      toggle.focus();
    }
  });

  desktopBreakpoint.addEventListener('change', (event) => {
    if (event.matches) setMenuOpen(false);
  });
</script>
