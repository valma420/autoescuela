---
import { site } from '../data/site';

const navItems = [
  { href: '#servicios', label: 'Servicios' },
  { href: '#cobertura', label: 'Zonas' },
  { href: '#profesor', label: 'Instructor' },
  { href: '#beneficios', label: 'Beneficios' },
];
---

<header class="fixed inset-x-0 top-0 z-40 bg-gradient-to-b from-brand-950/82 to-transparent">
  <div class="ak-container flex min-h-20 items-center justify-between gap-4 py-3">
    <a href="/" class="ak-focus flex items-center gap-3" aria-label={`${site.name} inicio`}>
      <img
        src={site.assets.logo}
        alt={site.name}
        width="864"
        height="391"
        class="h-14 w-auto max-w-[172px] object-contain"
      />
    </a>

    <nav class="hidden items-center gap-8 text-sm font-black text-white md:flex">
      {
        navItems.map((item) => (
          <a class="ak-focus transition hover:text-accent-300" href={item.href}>
            {item.label}
          </a>
        ))
      }
    </nav>

    <a
      href={site.contact.whatsappUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="ak-focus hidden min-h-12 items-center justify-center rounded-full bg-accent-400 px-5 text-sm font-black uppercase text-brand-950 shadow-[0_10px_24px_-4px_rgba(0,158,226,0.35)] transition hover:bg-brand-100 md:inline-flex"
    >
      Agendá
    </a>

    <button
      aria-controls="mobile-navigation"
      aria-expanded="false"
      aria-label="Abrir menú"
      class="ak-focus relative grid h-11 w-11 place-items-center rounded-full bg-white/10 text-white backdrop-blur md:hidden"
      data-menu-toggle
      type="button"
    >
      <span class="sr-only">Menú</span>
      <span class="absolute h-0.5 w-5 -translate-y-1.5 rounded-full bg-current"></span>
      <span class="absolute h-0.5 w-5 rounded-full bg-current"></span>
      <span class="absolute h-0.5 w-5 translate-y-1.5 rounded-full bg-current"></span>
    </button>
  </div>
</header>

<div
  aria-hidden="true"
  aria-label="Navegación móvil"
  class="invisible fixed inset-0 z-50 flex flex-col bg-brand-950 text-brand-100 opacity-0 transition-all duration-300 md:hidden"
  data-mobile-menu
  id="mobile-navigation"
  role="dialog"
>
  <div class="ak-container flex min-h-20 items-center justify-between gap-4 py-3">
    <a class="ak-focus flex items-center gap-3" href="/" aria-label={`${site.name} inicio`} data-menu-link>
      <img
        src={site.assets.logo}
        alt={site.name}
        width="864"
        height="391"
        class="h-14 w-auto max-w-[172px] object-contain"
      />
    </a>
    <button
      aria-label="Cerrar menú"
      class="ak-focus relative grid h-11 w-11 place-items-center text-brand-100"
      data-menu-close
      type="button"
    >
      <span class="absolute h-0.5 w-5 rotate-45 rounded-full bg-current"></span>
      <span class="absolute h-0.5 w-5 -rotate-45 rounded-full bg-current"></span>
    </button>
  </div>

  <div class="ak-container flex flex-1 flex-col pb-9 pt-14">
    <p class="text-[0.65rem] font-black tracking-[0.14em] text-accent-300 uppercase">Menú</p>
    <nav aria-label="Navegación móvil" class="mt-2">
      <ul>
        {
          navItems.map((item, index) => (
            <li class={index === 0 ? '' : 'border-t border-brand-100/25'}>
              <a
                class="ak-focus flex min-h-[4.3rem] items-center font-display text-3xl font-black tracking-[-0.04em] text-brand-100 transition hover:text-accent-300"
                href={item.href}
                data-menu-link
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
    <a
      href={site.contact.whatsappUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="ak-focus mt-auto inline-flex min-h-[3.25rem] w-full items-center justify-center rounded-full bg-accent-400 px-5 text-xs font-black uppercase text-brand-950 transition hover:bg-brand-100"
      data-menu-link
    >
      Agendá tu clase
    </a>
    <p class="mt-8 text-[0.65rem] font-black tracking-[0.12em] text-brand-100 uppercase">
      {site.location.area} · {site.location.regionShort}
    </p>
  </div>
</div>

<script>
  const menu = document.querySelector<HTMLElement>('[data-mobile-menu]');
  const toggle = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
  const closeButton = document.querySelector<HTMLButtonElement>('[data-menu-close]');
  const menuLinks = menu?.querySelectorAll<HTMLAnchorElement>('[data-menu-link]');
  const desktopBreakpoint = window.matchMedia('(min-width: 768px)');
  let previousOverflow = '';

  const setMenuOpen = (open: boolean) => {
    if (!menu || !toggle) return;

    menu.classList.toggle('invisible', !open);
    menu.classList.toggle('pointer-events-none', !open);
    menu.classList.toggle('opacity-0', !open);
    menu.classList.toggle('opacity-100', open);
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú');
    menu.setAttribute('aria-hidden', String(!open));

    if (open) {
      previousOverflow = document.body.style.overflow;
      document.body.style.overflow = 'hidden';
      closeButton?.focus();
      return;
    }

    document.body.style.overflow = previousOverflow;
  };

  toggle?.addEventListener('click', () => {
    setMenuOpen(toggle.getAttribute('aria-expanded') !== 'true');
  });

  closeButton?.addEventListener('click', () => {
    setMenuOpen(false);
    toggle?.focus();
  });

  menuLinks?.forEach((link) => link.addEventListener('click', () => setMenuOpen(false)));

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && toggle?.getAttribute('aria-expanded') === 'true') {
      setMenuOpen(false);
      toggle.focus();
    }
  });

  desktopBreakpoint.addEventListener('change', (event) => {
    if (event.matches) setMenuOpen(false);
  });
</script>
