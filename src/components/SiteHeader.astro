---
import { site } from '../data/site';

const navItems = [
  { href: '#servicios', label: 'Servicios' },
  { href: '#cobertura', label: 'Zonas' },
  { href: '#profesor', label: 'Instructor' },
  { href: '#beneficios', label: 'Beneficios' },
];
---

<header class="fixed inset-x-0 top-0 z-40 bg-gradient-to-b from-brand-950/82 to-transparent">
  <div class="ak-container flex min-h-20 items-center justify-between gap-4 py-3">
    <a href="/" class="ak-focus flex items-center gap-3" aria-label={`${site.name} inicio`}>
      <img
        src={site.assets.logo}
        alt={site.name}
        width="864"
        height="391"
        class="h-14 w-auto max-w-[172px] object-contain"
      />
    </a>

    <nav class="hidden items-center gap-8 text-sm font-black text-white md:flex">
      {
        navItems.map((item) => (
          <a class="ak-focus transition hover:text-accent-300" href={item.href}>
            {item.label}
          </a>
        ))
      }
    </nav>

    <a
      href={site.contact.whatsappUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="ak-focus hidden min-h-12 items-center justify-center rounded-full bg-accent-400 px-5 text-sm font-black uppercase text-brand-950 shadow-[0_10px_24px_-4px_rgba(0,158,226,0.35)] transition hover:bg-brand-100 md:inline-flex"
    >
      Agendá
    </a>

    <details class="group relative md:hidden">
      <summary
        aria-label="Abrir menú"
        class="ak-focus flex h-11 w-11 cursor-pointer list-none items-center justify-center rounded-full bg-white/10 text-white backdrop-blur [&::-webkit-details-marker]:hidden"
      >
        <span class="sr-only">Menú</span>
        <span class="relative h-4 w-5" aria-hidden="true">
          <span class="absolute left-0 top-0 h-0.5 w-5 rounded-full bg-current transition group-open:top-1.5 group-open:rotate-45"></span>
          <span class="absolute left-0 top-1.5 h-0.5 w-5 rounded-full bg-current transition group-open:opacity-0"></span>
          <span class="absolute left-0 top-3 h-0.5 w-5 rounded-full bg-current transition group-open:top-1.5 group-open:-rotate-45"></span>
        </span>
      </summary>
      <div
        class="absolute right-0 top-14 w-[min(342px,calc(100vw-44px))] rounded-md border border-white/8 bg-brand-950 p-4 shadow-[0_18px_40px_-12px_rgba(0,0,0,0.55)]"
      >
        <nav class="divide-y divide-white/8">
          {
            navItems.map((item) => (
              <a class="ak-focus block py-4 font-display text-2xl font-black text-white" href={item.href}>
                {item.label}
              </a>
            ))
          }
        </nav>
        <a
          href={site.contact.whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="ak-focus mt-5 inline-flex min-h-12 w-full items-center justify-center rounded-full bg-accent-400 px-5 text-xs font-black uppercase text-brand-950 transition hover:bg-brand-100"
        >
          Agendá tu clase
        </a>
      </div>
    </details>
  </div>
</header>
