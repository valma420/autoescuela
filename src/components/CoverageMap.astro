---
import { coverage } from '../data/site';
---

<section id="cobertura" class="ak-section relative bg-brand-950 text-white">
  <div class="ak-container">
    <p class="absolute left-[22px] top-[30px] text-[13px] font-semibold tracking-[2px] text-accent-400">02</p>

    <div class="grid gap-5 lg:grid-cols-[0.8fr_1.2fr] lg:items-start lg:gap-12">
      <div>
        <h2 class="font-display text-[33px] font-black leading-[1.04] tracking-[-0.015em] sm:text-5xl">
          {coverage.title}
        </h2>
        <p class="mt-5 max-w-lg text-base leading-6 text-brand-100 md:text-lg md:leading-7">
          {coverage.description}
        </p>
      </div>

      <div>
        <div
          class="relative h-[220px] overflow-hidden rounded-[20px] border border-brand-750 bg-brand-800 bg-[linear-gradient(to_right,#33356a_1px,transparent_1px),linear-gradient(to_bottom,#33356a_1px,transparent_1px)] bg-[size:50px_44px]"
          role="img"
          aria-label="Representación gráfica de la zona de clases con base en Villa Urquiza"
        >
          <span class="absolute left-[35%] top-[31%] h-2.5 w-2.5 rounded-full bg-accent-400"></span>
          <span class="absolute left-[61%] top-[49%] h-2 w-2 rounded-full bg-accent-400"></span>
          <span class="absolute left-[27%] top-[68%] h-2 w-2 rounded-full bg-accent-400"></span>
          <span class="absolute left-[76%] top-[27%] h-2 w-2 rounded-full bg-accent-400"></span>
          <span class="absolute left-[51%] top-[72%] h-2 w-2 rounded-full bg-accent-400"></span>
          <span class="absolute left-[47%] top-[43%] h-[18px] w-[18px] rounded-full border-[3px] border-white bg-accent-500"></span>
          <span class="absolute left-[47%] top-[55%] text-xs font-semibold tracking-[0.04em] text-brand-100 uppercase">Villa Urquiza</span>
        </div>

        <ul class="mt-5 flex flex-wrap gap-2">
          {
            coverage.areas.map((area) => (
              <li class="inline-flex min-h-9 items-center gap-2 rounded-full border border-brand-750 bg-brand-800 px-[13px] text-[13px] font-medium text-brand-100">
                <span class="ak-dot"></span>
                {area}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
