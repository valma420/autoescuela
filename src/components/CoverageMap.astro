---
import 'leaflet/dist/leaflet.css';
import { coverage } from '../data/site';
---

<section id="cobertura" class="ak-section bg-brand-950 text-white">
  <div class="ak-container">
    <div class="grid gap-9 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
      <div>
        <h2 class="font-display text-4xl font-black uppercase leading-[0.95] sm:text-5xl">
          {coverage.title}
        </h2>
        <p class="mt-5 max-w-lg text-base leading-7 text-brand-100/85 md:text-lg">
          {coverage.description}
        </p>

        <ul class="mt-7 flex flex-wrap gap-2">
          {
            coverage.areas.map((area) => (
              <li class="ak-pill bg-brand-800 text-brand-100">
                <span class="ak-dot"></span>
                {area}
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <div
          class="overflow-hidden rounded-md border border-brand-100/10 bg-brand-800 shadow-[0_18px_36px_-20px_rgba(0,0,0,0.8)]"
        >
          <div
            id="coverage-map"
            data-coverage-map
            class="h-[260px] w-full saturate-[0.85] md:h-[360px] lg:h-[430px]"
            role="img"
            aria-label="Mapa interactivo de zonas de cobertura de AKDemia autoescuela"
          >
          </div>
        </div>

        <p
          data-coverage-map-status
          class="mt-4 hidden rounded-md border border-accent-400/35 bg-brand-800 px-4 py-3 text-sm font-semibold text-brand-100"
        >
          No pudimos cargar el mapa interactivo. Abajo tenés el listado de zonas cubiertas.
        </p>

        <p class="mt-5 text-sm font-semibold leading-6 text-brand-100/75">
          Zona base: {coverage.areas.join(', ')}.
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  import '../scripts/coverage-map';
</script>
