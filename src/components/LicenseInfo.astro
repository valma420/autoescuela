---
import { licenseInfo } from '../data/site';
---

<section id="licencia" class="ak-section bg-brand-950 text-white">
  <div class="ak-container">
    <div class="grid gap-8 lg:grid-cols-[0.75fr_1.25fr] lg:items-start">
      <div>
        <h2 class="font-display text-[30px] font-bold leading-[1.04] sm:text-5xl">
          {licenseInfo.title}
        </h2>
        <p class="mt-[18px] max-w-md text-[15px] leading-[1.5] text-brand-100">
          {licenseInfo.description}
        </p>
      </div>

      <ul class="grid gap-3 md:grid-cols-2">
        {
          licenseInfo.items.map((item) => (
            <li class="rounded-[16px] border border-brand-750 bg-brand-800 px-5 pb-5 pt-[18px]">
              <span class="block h-[3px] w-7 rounded-full bg-accent-400" aria-hidden="true"></span>
              <h3 class="mt-2 text-base font-semibold leading-[1.2] text-white">{item.title}</h3>
              <p class="mt-2 text-sm leading-[1.45] text-brand-100">{item.description}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>
