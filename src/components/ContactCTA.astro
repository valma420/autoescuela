---
import { contactCta, site } from '../data/site';
---

<section id="contacto" class="bg-brand-700 py-16 sm:py-20">
  <div class="mx-auto max-w-3xl px-4 text-center">
    <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
      {contactCta.title}
    </h2>
    <p class="mx-auto mt-4 max-w-xl text-lg text-brand-100">
      {contactCta.description}
    </p>

    <div class="mt-8 flex flex-col items-center gap-4">
      <a
        href={site.contact.whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2 rounded-xl bg-accent-500 px-8 py-4 text-lg font-semibold text-white shadow-lg transition hover:bg-accent-600 focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-brand-700"
      >
        💬 {contactCta.cta}
      </a>
      <p class="text-sm text-brand-100">
        {site.contact.phoneDisplay} · {site.contact.schedule}
      </p>
    </div>
  </div>
</section>
