---
import { contactCta, site } from '../data/site';
---

<section id="contacto" class="bg-white px-4 py-16 sm:py-24">
  <div
    class="relative isolate mx-auto max-w-6xl overflow-hidden rounded-lg bg-brand-950 px-6 py-14 text-center shadow-2xl sm:px-10 sm:py-20"
  >
    <img
      src={site.assets.ctaImage}
      alt=""
      width="1200"
      height="800"
      loading="lazy"
      class="absolute inset-0 -z-20 h-full w-full object-cover"
    />
    <div class="absolute inset-0 -z-10 bg-brand-950/82"></div>

    <p class="text-sm font-bold uppercase tracking-[0.22em] text-accent-400">
      Contacto
    </p>
    <h2 class="mx-auto mt-3 max-w-2xl text-3xl font-black tracking-tight text-white sm:text-5xl">
      {contactCta.title}
    </h2>
    <p class="mx-auto mt-5 max-w-xl text-lg leading-8 text-slate-200">
      {contactCta.description}
    </p>

    <div class="mt-8 flex flex-col items-center gap-4">
      <a
        href={site.contact.whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center rounded-full bg-accent-400 px-8 py-4 text-lg font-black text-brand-950 shadow-lg transition hover:bg-accent-300 focus:outline-none focus-visible:ring-2 focus-visible:ring-accent-300 focus-visible:ring-offset-2 focus-visible:ring-offset-brand-950"
      >
        {contactCta.cta}
      </a>
      <p class="text-sm font-semibold text-slate-200">
        {site.contact.phoneDisplay} · {site.contact.schedule}
      </p>
    </div>
  </div>
</section>
