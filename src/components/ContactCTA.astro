---
import { contactCta, site } from '../data/site';
---

<section id="contacto" class="ak-section bg-brand-950 text-white">
  <div class="ak-container">
    <p class="text-xs font-black uppercase tracking-[0.32em] text-accent-300">
      Empezá hoy
    </p>
    <h2 class="font-display mt-4 max-w-3xl text-4xl font-black uppercase leading-[0.94] sm:text-6xl">
      {contactCta.title}
    </h2>
    <p class="mt-6 max-w-xl text-base leading-7 text-brand-100/82 md:text-lg md:leading-8">
      {contactCta.description}
    </p>

    <div class="mt-8 flex flex-col items-start gap-4 sm:flex-row sm:items-center">
      <a
        href={site.contact.whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="ak-focus inline-flex min-h-12 w-full items-center justify-center rounded-full bg-accent-400 px-8 text-xs font-black uppercase text-brand-950 shadow-[0_14px_30px_-12px_rgba(0,158,226,0.75)] transition duration-200 hover:-translate-y-0.5 hover:bg-white sm:w-auto"
      >
        {contactCta.cta}
      </a>
      <p class="text-sm font-semibold text-brand-100/75">
        {site.contact.phoneDisplay} · {site.contact.schedule}
      </p>
    </div>
  </div>
</section>
