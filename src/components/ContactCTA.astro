---
import { contactCta, site } from '../data/site';
---

<section id="contacto" class="bg-brand-950 py-[54px] text-white md:py-[5.5rem]">
  <div class="ak-container">
    <p class="text-[13px] font-semibold leading-none tracking-[0.08em] text-brand-200 uppercase">
      Empezá hoy
    </p>
    <h2 class="font-display mt-[18px] max-w-3xl text-[32px] font-black leading-[1.04] tracking-[-0.015em] sm:text-6xl">
      {contactCta.title}
    </h2>
    <p class="mt-[18px] max-w-xl text-base leading-6 text-brand-100 md:text-lg md:leading-8">
      {contactCta.description}
    </p>

    <div class="mt-[18px] flex flex-col items-start gap-4 sm:flex-row sm:items-center">
      <a
        href={site.contact.whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="ak-focus inline-flex min-h-[50px] w-full items-center justify-center rounded-full bg-accent-400 px-8 text-xs font-semibold tracking-[0.04em] uppercase text-brand-950 transition duration-200 hover:-translate-y-0.5 hover:bg-white sm:w-auto"
      >
        {contactCta.cta}
      </a>
      <p class="hidden text-sm font-semibold text-brand-100/75 sm:block">
        {site.contact.phoneDisplay} · {site.contact.schedule}
      </p>
    </div>
  </div>
</section>
