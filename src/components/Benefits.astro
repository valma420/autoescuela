---
import { benefits } from '../data/site';
---

<section id="beneficios" class="bg-brand-950 py-16 text-white sm:py-24">
  <div class="mx-auto max-w-6xl px-4">
    <div class="max-w-2xl">
      <p class="text-sm font-bold uppercase tracking-[0.22em] text-accent-400">
        Beneficios
      </p>
      <h2 class="mt-3 text-3xl font-black tracking-tight sm:text-5xl">
        Por qué aprender con nosotros
      </h2>
      <p class="mt-4 text-lg leading-8 text-slate-300">
        Una forma simple y tranquila de aprender a manejar.
      </p>
    </div>

    <ul class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {
        benefits.map((benefit) => (
          <li class="rounded-lg border border-white/10 bg-white/[0.06] p-6 shadow-xl shadow-black/10">
            <span
              class="grid h-12 w-12 place-items-center rounded-lg bg-accent-400 text-2xl"
              aria-hidden="true"
            >
              {benefit.icon}
            </span>
            <h3 class="mt-5 text-lg font-black text-white">{benefit.title}</h3>
            <p class="mt-3 text-sm leading-6 text-slate-300">{benefit.description}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
