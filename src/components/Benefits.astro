---
import { benefits } from '../data/site';
---

<section id="beneficios" class="ak-section bg-brand-100 text-brand-950">
  <div class="ak-container">
    <div class="max-w-xl">
      <h2 class="font-display text-4xl font-black uppercase leading-[0.94] sm:text-5xl">
        Seguridad que se nota
      </h2>
    </div>

    <ul class="mt-8 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
      {
        benefits.map((benefit) => (
          <li class="rounded-md bg-white p-5 shadow-[0_10px_24px_-14px_rgba(25,26,51,0.4)]">
            <span class="block h-1 w-10 rounded-full bg-accent-400" aria-hidden="true"></span>
            <span class="mt-3 block text-xs font-black uppercase tracking-[0.24em] text-accent-500">
              {benefit.icon}
            </span>
            <h3 class="mt-3 min-h-12 text-lg font-black leading-6">{benefit.title}</h3>
            <p class="mt-3 text-sm leading-6 text-brand-800/75">{benefit.description}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
