---
import { benefits } from '../data/site';
---

<section id="beneficios" class="bg-white py-16 sm:py-20">
  <div class="mx-auto max-w-6xl px-4">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
        Por qué aprender con nosotros
      </h2>
      <p class="mt-4 text-lg text-slate-600">
        Una forma simple y tranquila de aprender a manejar.
      </p>
    </div>

    <ul class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        benefits.map((benefit) => (
          <li class="flex flex-col items-center rounded-2xl bg-brand-50 p-6 text-center">
            <span class="text-3xl" aria-hidden="true">
              {benefit.icon}
            </span>
            <h3 class="mt-4 text-base font-semibold text-slate-900">
              {benefit.title}
            </h3>
            <p class="mt-2 text-sm text-slate-600">{benefit.description}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
