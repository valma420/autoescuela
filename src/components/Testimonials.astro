---
import { testimonials } from '../data/site';
---

<section id="testimonios" class="bg-slate-100 py-16 sm:py-24">
  <div class="mx-auto max-w-6xl px-4">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div class="max-w-2xl">
        <p class="text-sm font-bold uppercase tracking-[0.22em] text-brand-600">
          Testimonios
        </p>
        <h2 class="mt-3 text-3xl font-black tracking-tight text-brand-950 sm:text-5xl">
          Lo que dicen los alumnos
        </h2>
      </div>
      <p class="max-w-sm text-base leading-7 text-slate-600">
        Personas que aprendieron a manejar con nosotros en Villa Urquiza.
      </p>
    </div>

    <ul class="mt-12 grid gap-6 md:grid-cols-3">
      {
        testimonials.map((t) => (
          <li class="flex min-h-64 flex-col rounded-lg border border-slate-200 bg-white p-6 shadow-lg shadow-slate-200/60">
            <p class="text-sm tracking-[0.18em] text-accent-600" aria-label="5 de 5 estrellas">
              ★★★★★
            </p>
            <blockquote class="mt-5 flex-1 text-lg font-semibold leading-8 text-brand-950">
              “{t.text}”
            </blockquote>
            <footer class="mt-6 border-t border-slate-200 pt-4 text-sm">
              <span class="font-black text-brand-950">{t.name}</span>
              <span class="text-slate-500"> · {t.context}</span>
            </footer>
          </li>
        ))
      }
    </ul>
  </div>
</section>
