---
import { testimonials } from '../data/site';
---

<section id="testimonios" class="bg-white py-16 sm:py-20">
  <div class="mx-auto max-w-6xl px-4">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
        Lo que dicen los alumnos
      </h2>
      <p class="mt-4 text-lg text-slate-600">
        Personas que aprendieron a manejar con nosotros en Villa Urquiza.
      </p>
    </div>

    <ul class="mt-12 grid gap-6 md:grid-cols-3">
      {
        testimonials.map((t) => (
          <li class="flex flex-col rounded-2xl border border-slate-200 bg-slate-50 p-6">
            <p class="text-yellow-500" aria-label="5 de 5 estrellas">
              ★★★★★
            </p>
            <blockquote class="mt-3 flex-1 text-slate-700">“{t.text}”</blockquote>
            <footer class="mt-4 text-sm">
              <span class="font-semibold text-slate-900">{t.name}</span>
              <span class="text-slate-500"> · {t.context}</span>
            </footer>
          </li>
        ))
      }
    </ul>
  </div>
</section>
