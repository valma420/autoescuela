---
import { testimonials } from '../data/site';
---

<section id="testimonios" class="ak-section bg-brand-100 text-brand-950">
  <div class="ak-container">
    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div class="max-w-2xl">
        <h2 class="font-display text-4xl font-black uppercase leading-[0.96] sm:text-5xl">
          Lo que dicen los alumnos
        </h2>
      </div>
      <p class="max-w-sm text-base leading-7 text-brand-800/75">
        Personas que aprendieron a manejar con nosotros en Villa Urquiza.
      </p>
    </div>

    <ul class="mt-8 grid gap-3 md:grid-cols-3">
      {
        testimonials.map((t, index) => (
          <li class="flex min-h-64 flex-col rounded-md bg-white p-5 shadow-[0_10px_24px_-14px_rgba(25,26,51,0.4)]">
            <p class="text-xs font-black uppercase tracking-[0.24em] text-accent-500">
              {String(index + 1).padStart(2, '0')}
            </p>
            <blockquote class="mt-5 flex-1 text-lg font-black leading-8">
              “{t.text}”
            </blockquote>
            <footer class="mt-6 border-t border-brand-100 pt-4 text-sm">
              <span class="font-black">{t.name}</span>
              <span class="text-brand-800/60"> · {t.context}</span>
            </footer>
          </li>
        ))
      }
    </ul>
  </div>
</section>
